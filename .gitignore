# ==========================================
# 1. Project Dependencies (Banned from Git)
# ==========================================
node_modules/
.DS_Store
Thumbs.db

# ==========================================
# 2. Cypress Test Artifacts & Temp Files
# ==========================================
# This ignores anything written to your downloads folder during run-time
cypress/downloads/*

# Ignores screenshots and videos from local runs
cypress/screenshots/
cypress/videos/

# ==========================================
# 3. Security & Environments (CRITICAL)
# ==========================================
# Keeps your local secrets completely off GitHub
cypress.env.json
.env
.env.local

# Ignores the dynamic file used to pass account details between specs
last-account.json
last-created-account.json

# ==========================================
# 4. IDE / Editor Configurations
# ==========================================
.vscode/
.idea/